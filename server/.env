PORT=5000
# Replace with your MongoDB Atlas connection string (free at mongodb.com/cloud/atlas)
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/campusops
MONGO_URI=mongodb://localhost:27017/campusops
JWT_SECRET=supersecretcampusadminkey123
NODE_ENV=development

# ── Email (Gmail SMTP) ──────────────────────────────────────────────────────
# Step 1: Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
# Step 2: Create an App Password for "Mail" → copy the 16-char password (no spaces)
# Step 3: Paste below — emails will be sent automatically when adding faculty
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16char_app_password
COLLEGE_NAME=CampusOps Institute of Technology
